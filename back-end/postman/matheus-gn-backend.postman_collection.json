    {
      "name": "Inventory (admin)",
      "item": [
        {
          "name": "Registrar entrada manual de estoque",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Admin-Key", "value": "{{adminKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": \"{{bookId}}\",\n  \"quantity\": 10,\n  \"unitCost\": 25.50,\n  \"reason\": \"PURCHASE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/entries",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "entries"]
            }
          }
        },
        {
          "name": "Consultar saldo de estoque por livro",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{adminKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/inventory/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "books", "{{bookId}}"]
            }
          }
        },
        {
          "name": "Listar movimentações de estoque",
