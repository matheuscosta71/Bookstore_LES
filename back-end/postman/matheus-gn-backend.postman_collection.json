              "raw": "{\n  \"lines\": [\n    {\n      \"paymentType\": \"CREDIT_CARD\",\n      \"amount\": 100.00,\n      \"creditCardId\": \"{{cardId}}\",\n      \"couponCode\": null\n    }\n  ],\n  \"newCreditCard\": null,\n  \"saveNewCardToProfile\": null\n}"
