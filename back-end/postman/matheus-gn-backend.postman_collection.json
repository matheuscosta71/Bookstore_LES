{
  "info": {
    "name": "Matheus GN - Backend",
    "description": "API REST do e-commerce de livros (Spring Boot).\\n\\n**Variáveis:** `baseUrl` (ex.: http://localhost:8080), `customerId`, `bookId`, `adminKey`, etc.\\n\\n**Admin:** rotas em `/admin`, `/inventory`, `/analytics`, `/audit-logs` e algumas em `/books` exigem o header `X-Admin-Key` (valor em `app.admin.key` no `application.yml`).\\n\\n**Endereços:** `AddressType` aceita apenas `DELIVERY` ou `BILLING`.\\n\\n**RF0025 — Transações:** após `POST .../checkout/finalize`, `GET .../customers/{id}/transactions` lista linhas `PURCHASE` (total do pedido).\\n\\nDocumentação de regras: `README.md` na raiz do `back-end/`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "adminKey", "value": "", "type": "string" },
    { "key": "customerId", "value": "", "type": "string" },
    { "key": "addressId", "value": "", "type": "string" },
    { "key": "cardId", "value": "", "type": "string" },
    { "key": "bookId", "value": "", "type": "string" },
    { "key": "itemId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "orderItemId", "value": "", "type": "string" },
    { "key": "exchangeRequestId", "value": "", "type": "string" },
    { "key": "entityName", "value": "Customer", "type": "string" },
    { "key": "entityId", "value": "", "type": "string" },
    { "key": "startDate", "value": "2026-01-01", "type": "string" },
    { "key": "endDate", "value": "2026-01-31", "type": "string" },
    { "key": "orderStatus", "value": "EM_TROCA", "type": "string" },
    { "key": "movementType", "value": "ENTRY", "type": "string" }
  ],
